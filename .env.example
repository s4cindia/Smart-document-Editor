# Copy this file to ".env" and fill in real values. NEVER commit .env.
#   cp .env.example .env

# Flask session signing key. Generate one:  openssl rand -hex 32
SDE_SECRET_KEY=

# Postgres credentials (used by both the db and app services in compose).
POSTGRES_USER=sde
POSTGRES_PASSWORD=
POSTGRES_DB=smart_document_editor
